# Server
PORT=3000

# Database connection string used by the app (matches the values below for local Docker setup)
DATABASE_URL=postgres://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:<POSTGRES_PORT>/<POSTGRES_DB>

# Comma-separated list of origins allowed to make requests to this API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
REFRESH_TOKEN_EXPIRY_DAYS=7

# Postgres (used by docker-compose.yml for local development)
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name
POSTGRES_PORT=5432

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=your_google_client_url

FRONTEND_URL=your_frontend_url

REDIS_PORT=your_redis_port
REDIS_URL=your_redis_url
